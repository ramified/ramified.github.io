{
  "source": "js/sheaf_calculator.js:PICK_FLOW_REGISTRY",
  "last_verified": "2026-06-23",
  "notes": "Every current pick-flow id found in the registry is represented here. Predicates are descriptive, not executable.",
  "flows": [
    {
      "id": "identify",
      "slots": ["left", "right"],
      "activeWhen": "combinedIdentifyCreateMode()",
      "allowedObjectKinds": ["dynamic: identifyDraftKind()"],
      "candidateRule": "kind matches identifyDraftKind() and allowableIdentifyPick(id)",
      "completeWhen": "identifyConstructionData() returns data",
      "hintFunction": "identifyPickHint",
      "handler": "handleIdentifyPick"
    },
    {
      "id": "short-exact-sequence",
      "slots": ["sheaf-a", "map-ab", "sheaf-b", "map-bc", "sheaf-c"],
      "activeWhen": "combinedSesCreateMode()",
      "allowedObjectKinds": ["dynamic: map slots accept map, sheaf slots accept sheaf"],
      "candidateRule": "allowableSesSheafPick, allowableSesMapPick, or allowableSesFixedMapPick depending on slot and edit mode",
      "completeWhen": "shortExactSequenceData() returns data",
      "hintFunction": "sesPickHint",
      "handler": "handleSesPick"
    },
    {
      "id": "blowup",
      "slots": ["base", "point"],
      "activeWhen": "combinedBlowupCreateMode()",
      "allowedObjectKinds": ["variety"],
      "candidateRule": "allowableBlowupPick(id, state.blowupPickTarget)",
      "completeWhen": "blowupConstructionData() returns data",
      "hintFunction": "blowupPickHint",
      "handler": "handleBlowupPick"
    },
    {
      "id": "ramified-cover",
      "slots": ["base"],
